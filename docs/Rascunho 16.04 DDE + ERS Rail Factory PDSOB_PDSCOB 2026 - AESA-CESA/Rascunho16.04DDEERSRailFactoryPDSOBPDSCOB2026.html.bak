c128" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">VARCHAR(256)</span></p></td><td class="c105" colspan="1" rowspan="1"><p class="c12"><span>at&eacute;</span><span class="c4 c2">&nbsp;256</span></p></td><td class="c11" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">NOT NULL</span></p></td><td class="c93" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">N/D</span></p></td><td class="c57" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">Tipo da mensagem</span></p></td></tr><tr class="c99"><td class="c109" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">Payload</span></p></td><td class="c128" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">TEXT</span></p></td><td class="c105" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">vari&aacute;vel</span></p></td><td class="c11" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">NOT NULL</span></p></td><td class="c93" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">N/D</span></p></td><td class="c57" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">Conte&uacute;do serializado</span></p></td></tr><tr class="c99"><td class="c109" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">CreatedAtUtc</span></p></td><td class="c128" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">TIMESTAMPTZ</span></p></td><td class="c105" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">8 bytes</span></p></td><td class="c11" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">NOT NULL</span></p></td><td class="c93" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">now()</span></p></td><td class="c57" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">Data/hora de cria&ccedil;&atilde;o</span></p></td></tr><tr class="c99"><td class="c109" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">Processed</span></p></td><td class="c128" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">BOOLEAN</span></p></td><td class="c105" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">1 byte</span></p></td><td class="c11" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">NOT NULL</span></p></td><td class="c93" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">false</span></p></td><td class="c57" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">Indicador de processamento</span></p></td></tr><tr class="c99"><td class="c109" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">ProcessedAtUtc</span></p></td><td class="c128" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">TIMESTAMPTZ</span></p></td><td class="c105" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">8 bytes</span></p></td><td class="c11" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">NULL</span></p></td><td class="c93" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">N/D</span></p></td><td class="c57" colspan="1" rowspan="1"><p class="c12"><span class="c4 c2">Data/hora de processamento</span></p></td></tr></table><p class="c12"><span class="c1">Fonte: Produzido pelo autor</span></p><hr style="page-break-before:always;display:none;"><h2 class="c17 c16 c27" id="h.2qwf89wd7qvo"><span class="c4 c2"></span></h2><h2 class="c41" id="h.b32vspik9q4"><span class="c2">3.2 MODELAGEM COMPORTAMENTAL</span></h2><h3 class="c41" id="h.z6i643unesaa"><span class="c7 c5 c2">3.2.1 Diagrama de Sequ&ecirc;ncia&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span></h3><p class="c65 c56"><span class="c4 c2">Os diagramas de sequ&ecirc;ncia representam a ordem das intera&ccedil;&otilde;es entre atores, gateway, micro servi&ccedil;os, infraestrutura e sistemas externos. Eles cobrem os fluxos cr&iacute;ticos de autentica&ccedil;&atilde;o, roteamento por tenant, produ&ccedil;&atilde;o, recebimento inbound e despacho outbound.</span></p><p class="c27 c122"><span class="c4 c2"></span></p><p class="c47 c18 c16"><span class="c1">Figura 12 - Diagrama d