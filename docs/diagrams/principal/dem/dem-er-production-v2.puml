@startuml
title ER - Production (TO-BE) (v2)
left to right direction
skinparam linetype ortho

entity "Tenant" as Tenant {
  * id : uuid
  --
  name : string
}

entity "Material" as Material {
  * id : uuid
  --
  tenant_id : uuid
  sku : string
  name : string
  uom : string
  type : string <<raw/semi/finished>>
}

entity "Product" as Product {
  * id : uuid
  --
  tenant_id : uuid
  sku : string
  name : string
}

entity "BOM" as Bom {
  * id : uuid
  --
  tenant_id : uuid
  product_id : uuid
}

entity "BOMVersion" as BomVersion {
  * id : uuid
  --
  tenant_id : uuid
  bom_id : uuid
  version : int
  effective_from : date
  effective_to : date?
}

entity "BOMItem" as BomItem {
  * id : uuid
  --
  tenant_id : uuid
  bom_version_id : uuid
  material_id : uuid
  qty : decimal
  uom : string
}

entity "WorkCenter" as WorkCenter {
  * id : uuid
  --
  tenant_id : uuid
  code : string
  name : string
  type : string
}

entity "ProductionOrder" as OP {
  * id : uuid
  --
  tenant_id : uuid
  number : string
  product_id : uuid
  bom_version_id : uuid
  work_center_id : uuid
  status : string
  planned_qty : decimal
  started_at_utc : datetime?
  finished_at_utc : datetime?
}

entity "InventoryLot" as Lot {
  * id : uuid
  --
  tenant_id : uuid
  lot_number : string
  material_id : uuid
  type : string <<input/output>>
  created_at_utc : datetime
}

entity "LotLink" as LotLink {
  * output_lot_id : uuid
  * input_lot_id : uuid
}

entity "MaterialReservation" as Reservation {
  * id : uuid
  --
  tenant_id : uuid
  production_order_id : uuid
  lot_id : uuid?
  material_id : uuid
  qty : decimal
  status : string
}

entity "MaterialConsumption" as Consumption {
  * id : uuid
  --
  tenant_id : uuid
  production_order_id : uuid
  lot_id : uuid
  material_id : uuid
  qty : decimal
  at_utc : datetime
}

entity "Scrap" as Scrap {
  * id : uuid
  --
  tenant_id : uuid
  production_order_id : uuid
  material_id : uuid
  qty : decimal
  reason : string
  at_utc : datetime
}

entity "StopReason" as StopReason {
  * id : uuid
  --
  tenant_id : uuid
  code : string
  description : string
}

entity "Downtime" as Downtime {
  * id : uuid
  --
  tenant_id : uuid
  work_center_id : uuid
  production_order_id : uuid?
  stop_reason_id : uuid
  started_at_utc : datetime
  ended_at_utc : datetime?
}

entity "Inspection" as Inspection {
  * id : uuid
  --
  tenant_id : uuid
  production_order_id : uuid
  step : string
  result : string  <<approved/rejected>>
  at_utc : datetime
  notes : string?
}

Product ||--o{ Bom : has
Tenant ||--o{ Material
Tenant ||--o{ Product
Tenant ||--o{ Bom
Tenant ||--o{ WorkCenter
Tenant ||--o{ OP
Tenant ||--o{ Lot
Tenant ||--o{ StopReason
Bom ||--o{ BomVersion : versions
BomVersion ||--o{ BomItem : contains
Material ||--o{ BomItem : used_by
WorkCenter ||--o{ OP : executes
Product ||--o{ OP : produces
BomVersion ||--o{ OP : uses
Material ||--o{ Lot : lot_of
OP ||--o{ Reservation : reserves
OP ||--o{ Consumption : consumes
OP ||--o{ Scrap : scraps
WorkCenter ||--o{ Downtime : stops
StopReason ||--o{ Downtime : classified_as
OP ||--o{ Inspection : checks
Lot ||--o{ LotLink : output
Lot ||--o{ LotLink : input
Lot ||--o{ Reservation : optional_target
Lot ||--o{ Consumption : source

@enduml
