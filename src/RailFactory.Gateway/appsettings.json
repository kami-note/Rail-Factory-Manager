{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "iam-google-callback": {
        "ClusterId": "iam",
        "Match": {
          "Path": "/auth/google/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/iam/auth/google/{**catch-all}" },
          { "X-Forwarded": "Off" }
        ]
      },
      "tenancy-info": {
        "ClusterId": "tenancy",
        "Match": {
          "Path": "/api/tenancy/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/tenancy/{**catch-all}" }
        ]
      },
      "iam-info": {
        "ClusterId": "iam",
        "Match": {
          "Path": "/api/iam/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/iam/{**catch-all}" },
          { "X-Forwarded": "Off" }
        ]
      },
      "supply-chain-info": {
        "ClusterId": "supply-chain",
        "Match": {
          "Path": "/api/supply-chain/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/supply-chain/{**catch-all}" }
        ]
      },
      "inventory-info": {
        "ClusterId": "inventory",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/inventory/{**catch-all}" }
        ]
      },
      "production-info": {
        "ClusterId": "production",
        "Match": {
          "Path": "/api/production/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/production/{**catch-all}" }
        ]
      },
      "hr-info": {
        "ClusterId": "hr",
        "Match": {
          "Path": "/api/hr/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/hr/{**catch-all}" }
        ]
      },
      "fleet-info": {
        "ClusterId": "fleet",
        "Match": {
          "Path": "/api/fleet/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/fleet/{**catch-all}" }
        ]
      },
      "logistics-info": {
        "ClusterId": "logistics",
        "Match": {
          "Path": "/api/logistics/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/logistics/{**catch-all}" }
        ]
      }

    },
    "Clusters": {
      "tenancy": {
        "Destinations": {
          "tenancy": {
            "Address": "http://tenant-management"
          }
        }
      },
      "iam": {
        "Destinations": {
          "iam": {
            "Address": "http://identity-access-management"
          }
        }
      },
      "supply-chain": {
        "Destinations": {
          "supply-chain": {
            "Address": "http://supply-chain"
          }
        }
      },
      "inventory": {
        "Destinations": {
          "inventory": {
            "Address": "http://inventory"
          }
        }
      },
      "production": {
        "Destinations": {
          "production": {
            "Address": "http://production"
          }
        }
      },
      "hr": {
        "Destinations": {
          "hr": {
            "Address": "http://human-resources"
          }
        }
      },
      "fleet": {
        "Destinations": {
          "fleet": {
            "Address": "http://fleet"
          }
        }
      },
      "logistics": {
        "Destinations": {
          "logistics": {
            "Address": "http://logistics"
          }
        }
      }
    }
  }
}
